#!/bin/sh
set -eu

package_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd -P)
tools_root=$(CDPATH= cd -- "$package_root/.." && pwd -P)
pi_workspace=$(CDPATH= cd -- "$tools_root/../pi" && pwd -P)

export NODE_PATH="$pi_workspace/node_modules/.pnpm/node_modules:$pi_workspace/node_modules"
export PI_BIN="$tools_root/node_modules/.bin/pi"

exec "$package_root/node_modules/.bin/pi" "$@"
