{
  "defaultProvider": "openai-codex",
  "skills": ["~/.config/agents/skills"],
  "extensions": [
    "~/.pi/agent/extensions/editor",
    "~/.pi/agent/extensions/handoff.ts",
    "~/.pi/agent/extensions/session-name.ts",
    "~/.pi/agent/extensions/tool-harness.ts",
    "~/.pi/agent/extensions/system-prompt.ts",
    "~/.pi/agent/extensions/tools"
  ],
  "compaction": {
    "enabled": false
  },
  "lastChangelogVersion": "0.68.1",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "steeringMode": "all",
  "followUpMode": "all",
  "collapseChangelog": true,
  "doubleEscapeAction": "tree",
  "quietStartup": true,
  "enableSkillCommands": true,
  "showHardwareCursor": true,
  "transport": "auto",
  "terminal": {
    "showTerminalProgress": true
  },
  "treeFilterMode": "no-tools",
  "theme": "dark"
}
