{
  "defaultProvider": "openrouter",
  "skills": [
    "~/.config/agents/skills"
  ],
  "extensions": [
    "~/.pi/agent/extensions/editor",
    "~/.pi/agent/extensions/handoff.ts",
    "~/.pi/agent/extensions/session-name.ts",
    "~/.pi/agent/extensions/tool-harness.ts",
    "~/.pi/agent/extensions/system-prompt.ts",
    "~/.pi/agent/extensions/tools"
  ],
  "compaction": {
    "enabled": false
  },
  "lastChangelogVersion": "0.55.4",
  "defaultModel": "z-ai/glm-5",
  "defaultThinkingLevel": "medium",
  "hideThinkingBlock": false,
  "steeringMode": "all",
  "followUpMode": "all",
  "collapseChangelog": true,
  "doubleEscapeAction": "tree",
  "quietStartup": true,
  "enableSkillCommands": true,
  "showHardwareCursor": true
}