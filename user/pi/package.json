{
  "name": "@bdsqqq/pi",
  "version": "0.0.1",
  "description": "extensions and core utilities for pi-coding-agent",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdsqqq/dots.git",
    "directory": "user/pi"
  },
  "workspaces": {
    "packages": [
      "packages/core/*",
      "packages/extensions/*"
    ],
    "catalog": {
      "@mariozechner/pi-ai": "^0.62.0",
      "@mariozechner/pi-coding-agent": "^0.62.0",
      "@mariozechner/pi-tui": "^0.62.0"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./extensions": {
      "types": "./dist/extensions.d.ts",
      "import": "./dist/extensions.js"
    },
    "./extensions/*": {
      "types": "./dist/extensions/*.d.ts",
      "import": "./dist/extensions/*.js"
    },
    "./core/*": {
      "types": "./dist/core/*.d.ts",
      "import": "./dist/core/*.js"
    }
  },
  "scripts": {
    "sync:pi-extensions": "node ./scripts/sync-pi-extensions-manifest.mjs",
    "build": "node ./scripts/sync-pi-extensions-manifest.mjs && tsdown && node ./scripts/sync-pi-extensions-manifest.mjs",
    "lint": "oxlint --type-aware --format=stylish --type-check --report-unused-disable-directives",
    "lint:fix": "oxlint --type-aware --format=stylish --type-check --fix --report-unused-disable-directives",
    "lint:github": "oxlint --type-aware --type-check --format=github --report-unused-disable-directives",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "bun run --filter '@bds_pi/mermaid' typecheck && bun run --filter '@bds_pi/command-palette' typecheck && bun run --filter '@bds_pi/editor' typecheck",
    "test": "vitest run",
    "check": "bun run format && bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "cheerio": "^1.0.0",
    "diff": "^8.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^3.0.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": ">=0.62.0",
    "@mariozechner/pi-coding-agent": ">=0.62.0",
    "@mariozechner/pi-tui": ">=0.62.0",
    "@sinclair/typebox": ">=0.34.0"
  },
  "pi": {
    "extensions": [
      "./dist/extensions/bash.js",
      "./dist/extensions/code-review.js",
      "./dist/extensions/command-palette.js",
      "./dist/extensions/create-file.js",
      "./dist/extensions/edit-file.js",
      "./dist/extensions/editor.js",
      "./dist/extensions/finder.js",
      "./dist/extensions/format-file.js",
      "./dist/extensions/github.js",
      "./dist/extensions/glob.js",
      "./dist/extensions/grep.js",
      "./dist/extensions/handoff.js",
      "./dist/extensions/librarian.js",
      "./dist/extensions/look-at.js",
      "./dist/extensions/ls.js",
      "./dist/extensions/mentions.js",
      "./dist/extensions/mermaid.js",
      "./dist/extensions/oracle.js",
      "./dist/extensions/read.js",
      "./dist/extensions/read-session.js",
      "./dist/extensions/read-web-page.js",
      "./dist/extensions/search-sessions.js",
      "./dist/extensions/session-name.js",
      "./dist/extensions/skill.js",
      "./dist/extensions/system-prompt.js",
      "./dist/extensions/task.js",
      "./dist/extensions/tool-harness.js",
      "./dist/extensions/undo-edit.js",
      "./dist/extensions/web-search.js"
    ]
  }
}
